{
  "name": "sparql-formatter",
  "version": "1.0.0",
  "description": "SPARQL query formatter desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.sparqlformatter.app",
    "productName": "SPARQL Formatter",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "portable": {
      "artifactName": "SPARQL-Formatter-${version}-portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "formatter.js",
      "renderer/**",
      "node_modules/**",
      "assets/**"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.2.0",
    "sparqljs": "^3.7.4"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^22.14.13"
  }
}
